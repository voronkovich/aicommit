#!/usr/bin/env bash

set -euo pipefail
shopt -s lastpipe nullglob dotglob

declare -r app_name="${0##*/}"
declare -r cmd="${AICOMMIT_CMD:-gemini --prompt}"

main() {
    while [[ $# -gt 0 ]]; do
        case "${1:-}" in
        --init-commits)
            init_commits_file
            exit 0
            ;;
        --)
            shift
            break
            ;;
        -h | --help)
            help
            ;;
        -*)
            unknown_option "${1}"
            ;;
        *)
            break
            ;;
        esac
    done

    ensure_git_repo

    ensure_staged_changes

    declare -r prompt="$(generate_prompt)"

    info "Generating commit message..."
    declare -r commit_message="$(git diff --cached | ${cmd} "${prompt}" 2>/dev/null | tail -n1)"

    if [[ -z "${commit_message}" ]]; then
        fail "Failed to generate commit message."
    fi

    git commit -m "${commit_message}"
}

ensure_git_repo() {
    if git rev-parse --is-inside-work-tree &>/dev/null; then
        return
    fi

    echo -n "Not a git repository. Initialize a new one? (y/n): "
    read -n 1 -r
    echo
    if [[ ! ${REPLY} =~ ^[Yy]$ ]]; then
        fail "Git repository not initialized."
    fi
    info "Initializing new git repository..."

    git init
    git branch -M main
}

ensure_staged_changes() {
    if git diff --cached --exit-code --quiet; then
        info "No staged changes found. Adding all changes..."
        git add -A
        git ls-files --deleted -z | xargs -r0 git rm
    fi

    if git diff --cached --exit-code --quiet; then
        fail "No changes to commit at all."
    fi
}

generate_prompt() {
    echo "Generate a commit message."

    declare -r repo_root="$(git rev-parse --show-toplevel)"
    if [[ -f "${repo_root}/COMMITS.md" ]]; then
        cat "${repo_root}/COMMITS.md"
    else
        conventional_commits
    fi

    echo "Current branch: $(git branch --show-current)"
    echo "Recent commits: $(recent_commits)"
    echo "Analyze the diff and output only the commit message."
}

init_commits_file() {
    if ! git rev-parse --is-inside-work-tree &>/dev/null; then
        fail "Not a git repository."
    fi

    declare -r repo_root="$(git rev-parse --show-toplevel)"
    declare -r commits_file="${repo_root}/COMMITS.md"

    if [[ -f "${commits_file}" ]]; then
        fail "COMMITS.md already exists in repository root."
    fi

    conventional_commits >"${commits_file}"

    info "Created COMMITS.md with default Conventional Commits rules."
    info "Edit this file to customize commit message generation for your repository."
}

conventional_commits() {
    echo 'Use [Conventional Commits](https://www.conventionalcommits.org/) format:
- Format: `<type>(<scope>): <description>`
- Types: feat, fix, docs, style, refactor, perf, test, chore
- Description: imperative mood, lowercase, no period
- Keep under 72 characters
- Use scope only when relevant'
}

recent_commits() {
    if git rev-parse HEAD >/dev/null 2>&1; then
        echo
        git log --oneline -5 | prepend_lines '- '
    else
        echo "No recent commits"
    fi
}

prepend_lines() {
    while read -r line; do
        printf "%s%s\n" "${1}" "${line}"
    done
}

help() {
    echo -n "Usage: ${app_name} [options]

Analyzes staged changes using an AI model (default: gemini) to generate a concise
commit message following Conventional Commits specifications by default. Automatically
stages changes if none are staged, and can initialize a git repository if needed.

Custom commit rules can be defined by creating a COMMITS.md file in the repository root.
Use --init-commits to create a sample COMMITS.md with default rules.

Options:
  -h, --help       Show this help message and exit
  --init-commits   Create a sample COMMITS.md file in repository root

Environment variables:
  AICOMMIT_CMD     Command to use for AI generation (default: 'gemini --prompt')
                   Examples: 'qwen --prompt', 'openai --prompt'

COMMITS.md file:
  Place a COMMITS.md file in your repository root to define custom commit message rules.
  The content will be used as the AI prompt for generating commit messages.
  Use --init-commits to create a sample file with Conventional Commits rules.

Conventional commits format:
  <type>(<scope>): <description>
  Types: feat, fix, docs, style, refactor, perf, test, chore
  Rules: imperative mood, lowercase, no period, under 72 characters

Examples:
  ${app_name}                    # Generate and commit with AI message
  ${app_name} --init-commits     # Create sample COMMITS.md file
  ${app_name} --help             # Show this help
"
    exit 0
}

unknown_option() {
    fail "unknown option '${1}'
Try '${app_name} --help' for more information."
}

fail() {
    error "${1}"
    exit "${2:-1}"
}

error() {
    echo "${app_name}: ${1}" >&2
}

info() {
    echo "${1}"
}

main "$@"
